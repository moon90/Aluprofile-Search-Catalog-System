{
    "name":  "backend",
    "version":  "0.0.1",
    "description":  "",
    "author":  "",
    "private":  true,
    "license":  "UNLICENSED",
    "scripts":  {
                    "build":  "npx tsc -p tsconfig.build.json",
                    "format":  "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
                    "start":  "node dist/main",
                    "start:dev:no-watch":  "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
                    "start:dev":  "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
                    "start:debug":  "node --inspect -r ts-node/register -r tsconfig-paths/register src/main.ts",
                    "start:prod":  "node dist/main",
                    "prisma:generate":  "node \"./node_modules/prisma/build/index.js\" generate --schema prisma/schema.prisma",
                    "prisma:migrate":  "node \"./node_modules/prisma/build/index.js\" migrate dev --schema prisma/schema.prisma",
                    "prisma:studio":  "node \"./node_modules/prisma/build/index.js\" studio --schema prisma/schema.prisma",
                    "lint":  "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:cov":  "jest --coverage",
                    "test:debug":  "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
                    "test:e2e":  "jest --config ./test/jest-e2e.json"
                },
    "dependencies":  {
                         "@clerk/backend":  "^2.31.0",
                         "@nestjs/common":  "^11.0.1",
                         "@nestjs/core":  "^11.0.1",
                         "@nestjs/platform-express":  "^11.0.1",
                         "@prisma/client":  "^6.19.2",
                         "@sentry/node":  "^10.38.0",
                         "multer": "^1.4.5-lts.1",
                         "pg":  "^8.18.0",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1"
                     },
    "devDependencies":  {
                            "@eslint/eslintrc":  "^3.3.1",
                            "@eslint/js":  "^9.18.0",
                            "@nestjs/cli":  "^1.8.0",
                            "@nestjs/schematics":  "^11.0.0",
                            "@nestjs/testing":  "^11.0.1",
                            "@types/express":  "^5.0.0",
                            "@types/jest":  "^30.0.0",
                            "@types/multer": "^1.4.12",
                            "@types/node":  "^22.10.7",
                            "@types/supertest":  "^6.0.2",
                            "eslint":  "^9.39.1",
                            "eslint-config-prettier":  "^10.1.8",
                            "eslint-plugin-prettier":  "^5.5.4",
                            "globals":  "^16.0.0",
                            "jest":  "^30.0.0",
                            "prettier":  "^3.4.2",
                            "prisma":  "^6.19.2",
                            "source-map-support":  "^0.5.21",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.5",
                            "ts-loader":  "^9.5.2",
                            "ts-node":  "^10.9.2",
                            "tsconfig-paths":  "^4.2.0",
                            "typescript":  "^5.7.3",
                            "typescript-eslint":  "^8.14.0"
                        },
    "jest":  {
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "rootDir":  "src",
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  "ts-jest"
                               },
                 "collectCoverageFrom":  [
                                             "**/*.(t|j)s"
                                         ],
                 "coverageDirectory":  "../coverage",
                 "testEnvironment":  "node"
             }
}
